# Image coordinates
PLATFORM_VERSION=latest
BACKEND_IMAGE=ghcr.io/veriqorn/veriqorn-backend
FRONTEND_IMAGE=ghcr.io/veriqorn/veriqorn-frontend

# Public URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Core app secrets
JWT_SECRET=replace-with-long-random-secret

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=test_ops

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password

# Optional: public key for AI Pro signature verification.
# IMPORTANT: never put private signing keys in any docker env or image.
AI_ANALYSIS_LICENSE_PUBLIC_KEY=
